source "https://rubygems.org"

gem "jekyll", "~> 3.8.1"

# ffi 1.9.x no longer builds reliably on newer macOS / Darwin releases,
# while 1.17.x requires Ruby 3. Keep this project compatible with macOS Ruby 2.6.
gem "ffi", "~> 1.15.0"

gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

gem "wdm", "~> 0.1.0" if Gem.win_platform?
